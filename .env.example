# OpenAI API anahtarı (https://platform.openai.com/api-keys)
# Gerçek anahtarınızı .env dosyasına yazın; bu dosyayı şablon olarak bırakın.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opsiyonel: model seçimi (varsayılanlar aşağıda)
# OPENAI_LLM_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Classifier (vaka sınıflandırma) ve Researcher (regulation araştırma) ayrı modeller:
# OPENAI_CLASSIFIER_MODEL=gpt-5-nano
# OPENAI_RESEARCHER_MODEL=o3-deep-research

# Flight status (optional — refund kararı için gecikme/iptal doğrulama)
# Ücretsiz: https://aviationstack.com/signup/free (100 istek/ay)
# AVIATIONSTACK_ACCESS_KEY=your_key

# PostgreSQL (optional — decision cache; leave unset to skip DB)
# Option A: single URL
# DATABASE_URL=postgresql://user:password@localhost:5432/refund_db
# Option B: separate vars
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=refund_db
